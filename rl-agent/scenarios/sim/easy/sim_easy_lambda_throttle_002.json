{
  "id": "sim_easy_lambda_throttle_002",
  "difficulty": "easy",
  "title": "orders Lambda throttling",
  "description": "Customers report 5xx from /orders. CloudWatch alarm `orders-Throttles` is in ALARM. Fix the throttle.",
  "preconditions": [
    {
      "path": "lambda_/ic-orders",
      "op": "set",
      "value": {
        "name": "ic-orders",
        "state": "Active",
        "reserved_concurrency": 0,
        "invocations": 0,
        "errors": 0,
        "throttles": 5
      }
    }
  ],
  "scheduled_failures": [
    {
      "action_id": "lambda.invoke",
      "error": "TooManyRequestsException",
      "message": "Reserved concurrency = 0",
      "count": 1
    }
  ],
  "correct_action_chain": [
    {
      "id": "lambda.describe",
      "params": {
        "resource_id": "ic-orders"
      }
    },
    {
      "id": "lambda.invoke",
      "params": {
        "resource_id": "ic-orders"
      }
    },
    {
      "id": "lambda.scale",
      "params": {
        "resource_id": "ic-orders",
        "capacity": 25
      }
    },
    {
      "id": "lambda.invoke",
      "params": {
        "resource_id": "ic-orders"
      }
    }
  ],
  "target_score": 0.55,
  "max_steps": 16
}